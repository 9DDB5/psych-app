{
  "expo": {
    "name": "PsychSession",
    "slug": "psych-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "psych-app",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#3B5BDB"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {},
    "web": {
      "favicon": "./assets/images/icon.png",
      "name": "PsychSession",
      "shortName": "PsychSession",
      "description": "Registrazione sedute psicologiche",
      "themeColor": "#3B5BDB",
      "backgroundColor": "#3B5BDB"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "baseUrl": "/psych-app"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
